<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.ui.search.SearchFragment"
        android:label="Search">
        <action
            android:id="@+id/action_searchFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookmarkFragment"
        android:name="com.ui.bookmark.BookmarkFragment"
        android:label="Bookmark">
        <action
            android:id="@+id/action_bookmarkFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.ui.detail.DetailFragment"
        android:label="Detail">
        <argument android:name="title" app:argType="string" />
        <argument android:name="description" app:argType="string" android:defaultValue="" />
        <argument android:name="content" app:argType="string" android:defaultValue="" />
        <argument android:name="imageUrl" app:argType="string" android:defaultValue="" />
        <argument android:name="articleUrl" app:argType="string" android:defaultValue="" />
        <argument android:name="sourceName" app:argType="string" android:defaultValue="" />
        <argument android:name="author" app:argType="string" android:defaultValue="" />
        <argument android:name="publishedAt" app:argType="string" android:defaultValue="" />
    </fragment>
</navigation>
